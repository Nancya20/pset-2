# ─────────────────────────────────────────────────────────────────
# NY Taxi ELT Pipeline — Variables de Entorno
# Copia este archivo como .env y completa con tus valores reales.
# NUNCA subas .env al repositorio.
# ─────────────────────────────────────────────────────────────────

# ── PostgreSQL (secrets) ──────────────────────────────────────────
PG_USER=taxiuser
PG_PASSWORD=your_secure_password_here
PG_HOST=postgres
PG_PORT=5432
PG_DATABASE=nyc_taxi_db
PG_RAW_SCHEMA=raw
PG_CLEAN_SCHEMA=clean

# ── pgAdmin ───────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=your_pgadmin_password_here

# ── Rango de datos a procesar ─────────────────────────────────────
# Para demo/test usa 2 meses. Para producción: 2015-01 a 2025-12.
START_YEAR=2024
START_MONTH=1
END_YEAR=2024
END_MONTH=3

# ── Comportamiento de carga ───────────────────────────────────────
# false = saltar archivos ya cargados (idempotente)
# true  = forzar recarga aunque existan datos
FORCE_RELOAD=false
